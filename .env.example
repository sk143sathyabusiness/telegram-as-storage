# TeamVault Telegram Configuration
# Get a bot token from @BotFather on Telegram
VAULTX_BOT_TOKEN=your_bot_token_here

# Default Telegram channel/group chat ID for file storage
# (if not set per-org during registration)
VAULTX_CHAT_ID=-1001234567890

# Flask secret key (optional — auto-generated if not set)
SECRET_KEY=your_secret_key_here
