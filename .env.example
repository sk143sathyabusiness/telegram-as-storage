# ============================================================
# Telegram (Telethon userbot — NOT bot API)
# Get API_ID / API_HASH from https://my.telegram.org
# ============================================================
TG_API_ID=your_api_id
TG_API_HASH=your_api_hash
TG_SESSION_NAME=session_name          # matches session_name.session file
TG_PHONE=+91xxxxxxxxxx                 # used only during one-time interactive login

# Chunking (bytes) — stay under Telegram's ~2GB single-message limit
CHUNK_SIZE_BYTES=1900000000

# ============================================================
# Supabase
# ============================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key   # backend only, never expose to frontend
SUPABASE_ANON_KEY=your_anon_key                    # used by frontend for auth

# ============================================================
# Flask
# ============================================================
FLASK_SECRET_KEY=generate_a_long_random_string
FLASK_ENV=development                  # development | production
FLASK_PORT=5000

# ============================================================
# Encryption
# ============================================================
# Server never stores the raw team passphrase or derived key — only a
# verifier hash (see users.encryption_verifier in schema) to detect a
# wrong passphrase client-side. This salt is for that verifier only.
ENCRYPTION_VERIFIER_SALT=generate_a_random_salt

# ============================================================
# Master Admin bootstrap (first-run only)
# ============================================================
MASTER_ADMIN_USERNAME=admin
MASTER_ADMIN_BOOTSTRAP_PASSWORD=choose_a_strong_password

# ============================================================
# Zero local storage — all file bytes handled in-memory only
# (io.BytesIO), never written to disk. Telegram channels are the
# only persistent storage. Backups are Telegram-to-Telegram forwards.
# ============================================================
BACKUP_CHANNEL_ID=your_backup_channel_id