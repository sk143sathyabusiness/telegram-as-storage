# ============================================================
# Telegram (Telethon userbot — NOT bot API)
# Get API_ID / API_HASH from https://my.telegram.org
# ============================================================
TG_API_ID=your_api_id
TG_API_HASH=your_api_hash
TG_SESSION_NAME=session
TG_PHONE=+91XXXXXXXXXX

# ============================================================
# Chunking (bytes) — Telegram limits single messages to ~2GB
# Files > this size are automatically split into sequential
# chunks, each uploaded as a separate message.
#
# For 10GB files: 10GB / 1.9GB = ~6 chunks (sequential order)
# Leave at 1.9GB (1900000000) — safe margin under 2GB limit
# ============================================================
CHUNK_SIZE_BYTES=1900000000

# ============================================================
# Upload settings
# ============================================================
# Max file upload size in bytes (default 10GB)
# This is the Flask request body limit — must be >= your largest file
MAX_UPLOAD_SIZE=10737418240

# Concurrent chunk uploads (1 = sequential, 2-3 = faster for large files)
# Sequential is safest. Increase only if your machine has bandwidth.
# For files <2GB this has no effect (single chunk).
CONCURRENT_CHUNKS=1

# ============================================================
# Supabase
# ============================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# ============================================================
# Flask
# ============================================================
FLASK_SECRET_KEY=generate_a_long_random_string
FLASK_ENV=development
FLASK_PORT=5000

# ============================================================
# Encryption
# ============================================================
ENCRYPTION_VERIFIER_SALT=generate_a_random_salt

# ============================================================
# Master Admin bootstrap (first-run only)
# ============================================================
MASTER_ADMIN_USERNAME=admin
MASTER_ADMIN_BOOTSTRAP_PASSWORD=choose_a_strong_password

# ============================================================
# SMTP (for email sharing)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com
SMTP_FROM_NAME=TeamVault

# ============================================================
# Backup
# ============================================================
BACKUP_CHANNEL_ID=your_backup_channel_id
