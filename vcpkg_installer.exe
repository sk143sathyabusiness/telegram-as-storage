    }
</script>

<script type="text/javascript" src="https://js.monitor.azure.com/scripts/c/ms.analytics-web-4.min.js"></script>

<script type="text/javascript">
    function _getWcpUserConsentDetails() {
        if(siteConsent) {
            return siteConsent.getConsent();
        }
        return {
            Required: true,
            Analytics: false,
            SocialMedia: false,
            Advertising: false
        };
    }

    // QUICK FIX: Default to opt-out until consent/GPC is known
    if (typeof GPC_DataSharingOptIn === "undefined") {
        const gpcEnabled = (typeof navigator !== "undefined" && navigator.globalPrivacyControl === true);

        let consent = null;
        try {
            if (typeof siteConsent !== "undefined" && siteConsent) {
                consent = siteConsent.getConsent();
            }
        } catch (e) {}

        // Default false (opt-out)
        GPC_DataSharingOptIn = false;

