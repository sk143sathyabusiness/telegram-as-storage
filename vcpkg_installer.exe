        if (!gpcEnabled && consent && consent.Advertising === true) {
            GPC_DataSharingOptIn = true;
        }

        if (typeof WP_DEBUG !== 'undefined' && WP_DEBUG) {
            console.log("GPC_DataSharingOptIn computed (quick fix):", {
                value: GPC_DataSharingOptIn,
                gpc: gpcEnabled,
                consent: consent
            });
        }
    }

    // 1DS configuration
    var config = {
    instrumentationKey: "f194a55d6cb942d9b0e5b604e01b609b-8c663a24-3636-4cc5-a2bf-267a92b4ee4f-7662",
    channelConfiguration: {
        eventsLimitInMem: 5000
    },
    coreData: {
        appId: "VSCOM",
        market: adobePageMarket
